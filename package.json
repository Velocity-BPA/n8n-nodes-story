{
  "name": "n8n-nodes-story",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Story Protocol programmable IP infrastructure providing IP asset management, licensing, derivatives, royalties, and dispute resolution with 50+ operations.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-story.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-story#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-story/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "story-protocol",
    "ip-assets",
    "intellectual-property",
    "blockchain",
    "nft",
    "licensing",
    "royalties",
    "derivatives",
    "web3",
    "ethereum"
  ],
  "main": "dist/nodes/Story/Story.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/StoryProtocol.credentials.js",
      "dist/credentials/StoryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Story/Story.node.js",
      "dist/nodes/Story/StoryTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "copyfiles -u 1 \"nodes/**/*.svg\" \"nodes/**/*.png\" dist/",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "axios": "^1.6.2",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
